{
  "name": "@homelab/monitor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@homelab/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.6",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.36.4",
    "form-data": "^4.0.1",
    "hono": "^4.6.14",
    "mailgun.js": "^10.4.0",
    "pino": "^9.5.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.28.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
